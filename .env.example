# Runtime
APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-long-random-secret-at-least-32-characters
DATABASE_URL=file:./dev.db
MAX_RESUME_FILE_MB=8

# Environment controls
ENABLE_DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
AUTO_BOOTSTRAP_SCHEMA=true

# Request security
LOGIN_RATE_LIMIT_WINDOW_MS=300000
LOGIN_RATE_LIMIT_MAX_REQUESTS=12
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX_REQUESTS=180
WEBHOOK_SHARED_SECRET=replace-with-long-webhook-shared-secret

# AI Provider (optional)
OPENAI_API_KEY=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
ENABLE_SEMANTIC_EMBEDDINGS=false

# Resume storage (recommended in production)
RESUME_STORAGE_PROVIDER=local
BLOB_READ_WRITE_TOKEN=
VERCEL_BLOB_ACCESS=private

# Optional persistence (future Supabase integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
